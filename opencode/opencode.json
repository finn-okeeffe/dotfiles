{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff": "allow",
      "git log": "allow",
      "git show": "allow",
      "git blame": "allow",
      "git fetch": "allow",
      "ls": "allow",
      "pwd": "allow"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "external_directory": "ask",
    "lsp": "allow",
    "question": "allow",
    "todowrite": "allow"
  },
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": ["docker", "run", "-i", "--env-file", "/home/finn/.env", "--network", "host", "mcp/obsidian"],
      "enabled": true
    }
  }
}
